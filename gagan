<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trap Mind VR</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/0.160.0/three.min.js"></script>
</head>
<body class="bg-slate-900 m-0 overflow-hidden">
    <div id="root"></div>

    <script type="text/babel">
        // Note: In a single HTML file without a bundler, we simulate the imports 
        // from the global window objects provided by CDNs.
        const { useState, useEffect, useRef, Suspense } = React;
        const { Canvas, useFrame, useThree } = ReactThreeFiber;
        const { Sky, Box, Text, Cylinder, Environment, useXR, XR, createXRStore } = Drei;
        const { Physics, RigidBody, CapsuleCollider, useRapier } = ReactThreeRapier;

        const store = createXRStore();

        // --- Levels Data ---
        const LEVELS = [
            {
                startPos: [0, 2, 0],
                platforms: [
                    { id: 'p1', position: [0, 0, 0], size: [4, 0.5, 4], type: 'solid', color: '#475569' },
                    { id: 'p2', position: [0, 0, -5], size: [2, 0.5, 4], type: 'fake', color: '#64748b' },
                    { id: 'p3', position: [0, 0, -10], size: [4, 0.5, 4], type: 'solid', color: '#475569' },
                ],
                traps: [
                    { id: 't1', position: [0, 0.5, -5], size: [2, 0.5, 2], type: 'spike', color: '#ef4444' },
                ],
                doors: [{ id: 'd1', position: [0, 1.5, -11.5], isFake: false }],
                texts: [{ position: [0, 2, -2.5], text: 'Just a normal bridge.' }],
            },
            {
                startPos: [0, 2, 0],
                platforms: [
                    { id: 'p1', position: [0, 0, 0], size: [4, 0.5, 4], type: 'solid', color: '#475569' },
                    { id: 'p2', position: [0, 0, -6], size: [2, 0.5, 2], type: 'moving', color: '#0ea5e9', movement: { axis: 'x', distance: 3, speed: 2 } },
                    { id: 'p3', position: [0, 0, -12], size: [4, 0.5, 4], type: 'solid', color: '#475569' },
                ],
                traps: [
                    { id: 't1', position: [0, -0.5, -10], size: [2, 1, 2], type: 'hidden_spike', color: '#ef4444', triggerZone: { position: [0, 1, -8], size: [4, 2, 4] } },
                    { id: 't2', position: [0, 5, -12], size: [2, 2, 2], type: 'falling_block', color: '#334155', triggerZone: { position: [0, 1, -12], size: [4, 4, 4] } }
                ],
                doors: [{ id: 'd1', position: [0, 1.5, -13.5], isFake: false }],
                texts: [{ position: [0, 2, -2.5], text: 'Mind the gap.' }],
            },
            {
                startPos: [0, 2, 0],
                platforms: [
                    { id: 'p1', position: [0, 0, 0], size: [4, 0.5, 4], type: 'solid', color: '#475569' },
                    { id: 'p2', position: [0, 0, -5], size: [2, 0.5, 4], type: 'solid', color: '#475569' },
                    { id: 'p3', position: [-5, 0, -5], size: [4, 0.5, 4], type: 'solid', color: '#475569' },
                    { id: 'p4', position: [5, 0, -5], size: [4, 0.5, 4], type: 'solid', color: '#475569' },
                ],
                traps: [{ id: 't1', position: [0, 0.5, -5], size: [2, 0.5, 4], type: 'spike', color: '#ef4444' }],
                doors: [
                    { id: 'd1', position: [-5, 1.5, -6.5], isFake: true },
                    { id: 'd2', position: [5, 1.5, -6.5], isFake: false },
                ],
                texts: [{ position: [0, 2, -2], text: 'Choose wisely.' }],
            }
        ];

        // --- Audio Controller ---
        let audioCtx = null;
        const playSound = (type) => {
            if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            if (audioCtx.state === 'suspended') audioCtx.resume();
            const osc = audioCtx.createOscillator();
            const gain = audioCtx.createGain();
            osc.connect(gain); gain.connect(audioCtx.destination);
            const now = audioCtx.currentTime;
            
            if (type === 'jump') {
                osc.frequency.setValueAtTime(300, now); osc.frequency.exponentialRampToValueAtTime(600, now + 0.1);
                gain.gain.setValueAtTime(0.1, now); osc.start(now); osc.stop(now + 0.1);
            } else if (type === 'death') {
                osc.type = 'sawtooth'; osc.frequency.setValueAtTime(150, now);
                gain.gain.setValueAtTime(0.2, now); osc.start(now); osc.stop(now + 0.3);
            }
        };

        // --- Game Components ---
        const Player = ({ startPos, onDie }) => {
            const { origin } = useXR();
            const { camera } = useThree();
            const rigidBodyRef = useRef();
            const isGrounded = useRef(false);

            useFrame(() => {
                if (!rigidBodyRef.current) return;
                const velocity = rigidBodyRef.current.linvel();
                const keys = window.keys || {};
                let moveX = 0, moveZ = 0;

                if (keys['w'] || keys['ArrowUp']) moveZ = -1;
                if (keys['s'] || keys['ArrowDown']) moveZ = 1;
                if (keys['a'] || keys['ArrowLeft']) moveX = -1;
                if (keys['d'] || keys['ArrowRight']) moveX = 1;

                const forward = new THREE.Vector3(0, 0, -1).applyQuaternion(camera.quaternion);
                forward.y = 0; forward.normalize();
                const right = new THREE.Vector3(1, 0, 0).applyQuaternion(camera.quaternion);
                right.y = 0; right.normalize();

                const moveDir = forward.multiplyScalar(moveZ).add(right.multiplyScalar(moveX));
                rigidBodyRef.current.setLinvel({ x: moveDir.x * 4, y: velocity.y, z: moveDir.z * 4 }, true);

                if (keys[' '] && isGrounded.current) {
                    rigidBodyRef.current.setLinvel({ x: velocity.x, y: 6, z: velocity.z }, true);
                    isGrounded.current = false;
                    playSound('jump');
                }

                const pos = rigidBodyRef.current.translation();
                if (origin) origin.position.set(pos.x, pos.y, pos.z);
                else camera.position.set(pos.x, pos.y + 1.6, pos.z);

                if (pos.y < -10) onDie("You fell into the abyss!");
            });

            return (
                <RigidBody ref={rigidBodyRef} position={startPos} colliders={false} enabledRotations={[false, false, false]} name="player"
                    onCollisionEnter={(e) => { isGrounded.current = true; }}
                    onCollisionExit={() => { isGrounded.current = false; }}>
                    <CapsuleCollider args={[0.5, 0.3]} />
                </RigidBody>
            );
        };

        const Platform = ({ def }) => {
            const ref = useRef();
            const [isFalling, setIsFalling] = useState(false);
            useFrame((state) => {
                if (def.type === 'moving' && ref.current && def.movement) {
                    const time = state.clock.getElapsedTime();
                    const offset = Math.sin(time * def.movement.speed) * def.movement.distance;
                    const newPos = [...def.position];
                    const idx = {x:0, y:1, z:2}[def.movement.axis];
                    newPos[idx] += offset;
                    ref.current.setNextKinematicTranslation({x: newPos[0], y: newPos[1], z: newPos[2]});
                }
            });
            return (
                <RigidBody ref={ref} type={def.type === 'moving' ? 'kinematicPosition' : (isFalling ? 'dynamic' : 'fixed')} position={def.position} 
                    onCollisionEnter={(e) => { if(def.type === 'fake') setTimeout(() => setIsFalling(true), 200); }}>
                    <Box args={def.size}><meshStandardMaterial color={def.color} opacity={isFalling ? 0.5 : 1} transparent /></Box>
                </RigidBody>
            );
        };

        const GameScene = ({ levelIndex, onDie, onWin }) => {
            const level = LEVELS[levelIndex];
            return (
                <Physics gravity={[0, -15, 0]}>
                    <Sky sunPosition={[100, 20, 100]} />
                    <ambientLight intensity={0.5} />
                    <directionalLight position={[10, 10, 5]} intensity={1} castShadow />
                    <Player startPos={level.startPos} onDie={onDie} />
                    {level.platforms.map(p => <Platform key={p.id} def={p} />)}
                    {level.doors.map(d => (
                        <RigidBody key={d.id} type="fixed" sensor position={d.position} onIntersectionEnter={() => onWin()}>
                            <Box args={[1.5, 2.5, 0.2]}><meshStandardMaterial color="#8b5cf6" /></Box>
                        </RigidBody>
                    ))}
                    {level.texts.map((t, i) => <Text key={i} position={t.position} fontSize={0.5}>{t.text}</Text>)}
                </Physics>
            );
        };

        function App() {
            const [gameState, setGameState] = useState('start');
            const [levelIndex, setLevelIndex] = useState(0);
            const [deaths, setDeaths] = useState(0);

            useEffect(() => {
                window.keys = {};
                window.onkeydown = (e) => window.keys[e.key] = true;
                window.onkeyup = (e) => window.keys[e.key] = false;
            }, []);

            return (
                <div className="w-full h-screen relative">
                    <div className="absolute top-4 left-4 z-10 text-white font-mono">
                        <h1 className="text-2xl font-bold text-purple-400">Trap Mind VR</h1>
                        <p>Level: {levelIndex + 1} | Deaths: {deaths}</p>
                    </div>
                    <button onClick={() => store.enterVR()} className="absolute bottom-4 right-4 z-10 px-4 py-2 bg-purple-600 text-white rounded">Enter VR</button>
                    
                    <Canvas shadows camera={{ position: [0, 1.6, 5] }}>
                        <XR store={store}>
                            {gameState === 'playing' ? (
                                <GameScene 
                                    levelIndex={levelIndex} 
                                    onDie={(m) => { setDeaths(d => d+1); setGameState('start'); playSound('death'); }} 
                                    onWin={() => levelIndex < 2 ? setLevelIndex(l => l+1) : setGameState('start')} 
                                />
                            ) : (
                                <Text position={[0, 1.5, -2]} onClick={() => setGameState('playing')}>Click to Start</Text>
                            )}
                        </XR>
                    </Canvas>
                </div>
            );
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
    
    <script src="https://unpkg.com/three@0.
